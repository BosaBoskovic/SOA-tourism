{
  "id": null,
  "uid": "loki-logs",
  "title": "Agregacija Logova (Loki)",
  "description": "Logovi svih mikroservisa sakupljeni kroz Promtail → Loki",
  "tags": ["logs", "loki", "promtail", "soa-tourism"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Volume logova po kontejneru",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "sum(rate({job=\"docker\"}[5m])) by (filename)",
          "legendFormat": "{{filename}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1, "fillOpacity": 5 } }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 2,
      "title": "ERROR / WARN logovi — svih servisa",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "{job=\"docker\"} |~ \"(?i)(error|warn|exception|fatal)\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 3,
      "title": "Logovi — Gateway (soa-gateway)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "{job=\"docker\",filename=\"/var/lib/docker/containers/07d0dd3c72fd13915e0200a3431c6b507fd1767a384d52c8ccfee19971f5e793/07d0dd3c72fd13915e0200a3431c6b507fd1767a384d52c8ccfee19971f5e793-json.log\"}",
